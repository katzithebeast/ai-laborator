# Supabase — získáš na supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TVUJ-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tvuj-anon-key

# Anthropic — pouze na serveru, uživatelé ho nevidí
# Získáš na console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Google Drive — Service Account JSON (celý JSON na jeden řádek)
# Získáš na console.cloud.google.com → IAM → Service Accounts → Keys
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}

# ID složky na Google Drive, kam se budou nahrávat PDF (z URL složky)
GOOGLE_DRIVE_FOLDER_ID=1AbCdEfGhIjKlMnOpQrStUv
